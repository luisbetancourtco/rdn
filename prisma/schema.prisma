generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model NewsItem {
  id          Int       @id @default(autoincrement())
  guid        String    @unique
  title       String
  summary     String?
  url         String
  source      String
  category    String
  type        String?
  relevance   String?
  reason      String?
  status      String    @default("pendiente")
  caption     String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
