# Base URL (for OAuth redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase PostgreSQL (get from Supabase dashboard → Settings → Database)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Auth
APP_PASSWORD=cambia_esta_contrasena
SESSION_SECRET_KEY=genera_una_clave_aleatoria_de_al_menos_32_caracteres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn OAuth (optional — leave blank if not used)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback

# Ingestion settings
MAX_ITEM_AGE_DAYS=7
